{
  "name": "punch-tracker",
  "version": "1.0.0",
  "description": "Team Punch-In/Out Tracking System",
  "scripts": {
    "start": "node backend/src/server.js",
    "build": "npm install && cd frontend && npm install && npm run build",
    "dev:backend": "nodemon backend/src/server.js",
    "dev:frontend": "cd frontend && npm start",
    "install:all": "npm install && cd frontend && npm install"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "couchbase": "^4.3.0",
    "uuid": "^9.0.0",
    "@aws-sdk/client-sns": "^3.450.0",
    "@aws-sdk/client-s3": "^3.450.0",
    "@aws-sdk/client-rekognition": "^3.450.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}